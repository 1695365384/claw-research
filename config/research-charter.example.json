      "type": "exploratory",
      "priority": "critical"
    },
    {
      "id": "RQ2",
      "question": "Are users willing to pay for a solution?",
      "hypothesis": "Users with [specific criteria] would pay $X-Y/month",
      "type": "validation",
      "priority": "high"
    }
  ],
  "target_personas": [
    {
      "label": "Primary Target User",
