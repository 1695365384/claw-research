{
  "sources": {
    "hacker_news": {
      "type": "api",
      "url": "https://hn.algolia.com/api/v1/search_by_date",
      "requires_auth": false,
      "enabled": true,
      "keywords": ["技术", "产品", "startup", "痛点", "developer", "tool", "SaaS", "AI"],
      "description": "Hacker News 技术社区讨论"
    },
    "woshipm": {
      "type": "rss",
      "url": "https://www.woshipm.com/feed",
      "requires_auth": false,
      "enabled": true,
      "keywords": ["产品经理", "产品", "PM", "运营", "B端", "C端", "用户研究", "需求分析"],
      "description": "人人都是产品经理 - 中文PM社区"
    },
    "pmcaff": {
      "type": "rss",
      "url": "https://www.pmcaff.com/rss",
      "requires_auth": false,
      "enabled": true,
      "keywords": ["产品", "PM", "运营", "增长", "数据分析"],
      "description": "PMCAFF 产品经理社区"
    },
    "zhihu": {
      "type": "search",
      "url": "https://www.zhihu.com/search",
      "requires_auth": false,
      "enabled": true,
      "keywords": ["问答", "讨论", "痛点", "建议", "反馈", "产品", "工作", "职场"],
      "description": "知乎中文问答社区"
    },
    "reddit": {
      "type": "api",
      "subreddits": ["ProductManagement", "productmanager", "SaaS", "startups", "entrepreneur"],
      "requires_auth": true,
      "auth_type": "oauth",
      "auth_hint": "需要 Reddit API credentials (client_id, client_secret)。获取方式: https://www.reddit.com/prefs/apps",
      "enabled": true,
      "keywords": ["product", "pain point", "feedback", "SaaS", "startup", "discussion"],
      "description": "Reddit 社区讨论"
    },
    "twitter": {
      "type": "api",
      "requires_auth": true,
      "auth_type": "bearer_token",
      "auth_hint": "需要 Twitter API Bearer Token。获取方式: https://developer.twitter.com/",
      "enabled": false,
      "keywords": ["社交", "讨论", "趋势", "产品", "反馈"],
      "description": "Twitter 社交讨论 (需要 API)"
    },
    "product_hunt": {
      "type": "api",
      "url": "https://api.producthunt.com/v2/api/v2/posts",
      "requires_auth": true,
      "auth_type": "api_key",
      "auth_hint": "需要 Product Hunt API Token。获取方式: https://www.producthunt.com/v1/oauth/applications",
      "enabled": false,
      "keywords": ["product", "tool", "launch", "startup"],
      "description": "Product Hunt 产品发布平台 (需要 API)"
    },
    "google": {
      "type": "search",
      "engine": "google",
